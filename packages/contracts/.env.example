# RaiseDAO contracts (Hardhat) — copy to .env. Never commit a real private key.

# Arbitrum Sepolia RPC (falls back to the public endpoint if unset)
RPC_URL=

# Funded deployer key for testnet deploys — NEVER commit a real key
DEPLOYER_PRIVATE_KEY=

# Arbiscan key for contract verification
ARBISCAN_API_KEY=

# --- Optional deploy overrides (scripts/deploy.ts) ---
# USDC token the factory wires into every vault. Defaults to Circle USDC on
# Arbitrum Sepolia (0x75faf114eafb1BDbe2F0316DF893fd58CE46AA4d) if unset.
USDC_ADDRESS=

# Protocol-fee recipient. Defaults to the deployer address if unset.
FEE_RECIPIENT=

# Protocol fee in basis points taken from each milestone release. Defaults to 200 (2%).
PROTOCOL_FEE_BPS=200
