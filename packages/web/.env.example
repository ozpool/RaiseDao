# Web (Next.js) — only NEXT_PUBLIC_* vars reach the browser.
# Copy to .env.local and fill in. All values here are safe public placeholders.

# Base URL of the RaiseDAO API. Also the Socket.IO endpoint (the live tally
# connects to this same origin). Defaults to http://localhost:4000 if unset.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Deployed RaiseFactory address for the active network (Arbitrum Sepolia).
# Unset -> the create wizard's deploy step shows a clear "not configured" state.
# Print it from `pnpm -F @raisedao/contracts deploy:factory`.
NEXT_PUBLIC_FACTORY_ADDRESS=0xb88bb092A575d6CE82FbaDcC9a0216aE5BD1a765

# IPFS gateway used to fetch pinned evidence files. Defaults to the public
# ipfs.io gateway; swap for a dedicated gateway if you have one (no trailing slash).
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs
