# API server
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# MongoDB (Atlas connection string in production)
MONGODB_URI=mongodb://127.0.0.1:27017/raisedao

# Auth — JWT (set a strong secret in production) and SIWE
JWT_SECRET=dev-only-insecure-secret-change-me
JWT_EXPIRES_IN=7d
SIWE_DOMAIN=localhost:3000
SIWE_URI=http://localhost:3000
SIWE_CHAIN_ID=421614

# Comma-separated wallet addresses granted the admin role
ADMIN_ADDRESSES=

# Indexer (in-process). Disabled by default; set a deployed factory to enable.
INDEXER_ENABLED=false
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
FACTORY_ADDRESS=
INDEXER_START_BLOCK=0
INDEXER_CONFIRMATIONS=5
INDEXER_POLL_MS=12000

# IPFS evidence pinning. Provide at least one provider token; the API pins to
# Pinata first and falls back to web3.storage. EVIDENCE_MAX_BYTES caps uploads.
PINATA_JWT=
WEB3_STORAGE_TOKEN=
EVIDENCE_MAX_BYTES=10485760
