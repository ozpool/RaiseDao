# RaiseDAO API — copy to .env and fill in. Every var below is parsed and
# validated in src/config.ts; a missing/malformed value fails fast at boot.
# Values shown are safe defaults/placeholders — never commit real secrets.

# --- Core ---
NODE_ENV=development                       # development | test | production
PORT=4000                                  # HTTP port the API listens on
LOG_LEVEL=info                             # fatal|error|warn|info|debug|trace|silent
MONGODB_URI=mongodb://127.0.0.1:27017/raisedao   # Atlas connection string in prod

# --- Auth (JWT + SIWE) ---
JWT_SECRET=dev-only-insecure-secret-change-me    # >=16 chars; MUST be strong in prod
JWT_EXPIRES_IN=7d                          # JWT lifetime (e.g. 7d, 12h)
SIWE_DOMAIN=localhost:3000                 # domain the SIWE message must match
SIWE_URI=http://localhost:3000             # URI the SIWE message must match
SIWE_CHAIN_ID=421614                       # Arbitrum Sepolia
ADMIN_ADDRESSES=                           # comma-separated wallet addrs with admin role

# --- Indexer (in-process; runs inside this same API process) ---
INDEXER_ENABLED=false                      # true to start the chain indexer; needs FACTORY_ADDRESS
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc   # Arbitrum Sepolia RPC
FACTORY_ADDRESS=                           # deployed RaiseFactory; indexer discovers campaigns from it
INDEXER_START_BLOCK=0                      # block to begin indexing from
INDEXER_CONFIRMATIONS=5                    # reorg-safety depth before an event is treated as final
INDEXER_POLL_MS=12000                      # poll interval in ms

# --- IPFS evidence pinning ---
# Provide at least one provider token. The API pins to Pinata first and falls
# back to web3.storage; the upload route fails loudly only if every provider fails.
PINATA_JWT=
WEB3_STORAGE_TOKEN=
EVIDENCE_MAX_BYTES=10485760                # max upload size in bytes (10 MiB)

# --- Realtime (Socket.IO) ---
REALTIME_ENABLED=true                      # false disables the WebSocket gateway entirely
REDIS_URL=                                 # OPTIONAL Upstash URL; only adds the multi-instance adapter
APP_URL=http://localhost:3000              # web origin (CORS / links in emails)

# --- Email (Resend, transactional) ---
RESEND_API_KEY=                            # blank disables sending (no-op mailer)
EMAIL_FROM=RaiseDAO <notifications@raisedao.app>
